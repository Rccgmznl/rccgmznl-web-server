# Django Configuration
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Development-only key. Replace in production.
DJANGO_SECRET_KEY=django-insecure-change-me

DJANGO_LANGUAGE_CODE=en-us
DJANGO_TIME_ZONE=UTC
DJANGO_USE_I18N=true
DJANGO_USE_TZ=true

# Database
# Set to true to use SQLite instead of PostgreSQL.
DATABASE_USE_SQLITE=false
DATABASE_SQLITE_NAME=db.sqlite3

DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=rccgmznl
DATABASE_USER=postgres

# Required when using PostgreSQL.
DATABASE_PASSWORD=

DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
